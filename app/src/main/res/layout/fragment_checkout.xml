<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="?attr/colorPrimary">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_arrow_back_24"
            app:tint="@android:color/white"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginStart="16dp"
            android:textColor="@color/white"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_customer"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Searchable Select (Spinner-like) -->
            <TextView
                android:id="@+id/tvSelectedCustomer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/click_to_select_customer"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:drawableEndCompat="@android:drawable/arrow_down_float" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/or_create_new_customer"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:layout_gravity="center_horizontal"/>

            <EditText
                android:id="@+id/etCustomerName"
                android:layout_width="match_parent"
                android:maxWidth="@dimen/max_width"
                android:layout_height="wrap_content"
                android:hint="@string/customer_name"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:inputType="text"
                android:autofillHints="name"/>

            <EditText
                android:id="@+id/etCustomerPhone"
                android:layout_width="match_parent"
                android:maxWidth="@dimen/max_width"
                android:layout_height="wrap_content"
                android:hint="@string/phone_number"
                android:inputType="phone"
                android:autofillHints="tel"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etCustomerEmail"
                android:layout_width="match_parent"
                android:maxWidth="@dimen/max_width"
                android:layout_height="wrap_content"
                android:hint="@string/email_address"
                android:inputType="textEmailAddress"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:autofillHints="email"/>

            <EditText
                android:id="@+id/etCustomerAddress"
                android:layout_width="match_parent"
                android:maxWidth="@dimen/max_width"
                android:layout_height="wrap_content"
                android:hint="@string/address"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:inputType="textMultiLine"
                android:autofillHints="postalAddress"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_customer"
                android:layout_marginBottom="24dp"
                android:padding="12dp"
                app:cornerRadius="8dp"
                android:layout_gravity="center_horizontal"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/order_summary"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/items_0_total_kes_0_00"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitOrder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/submit_order"
        android:layout_margin="16dp"
        android:padding="12dp"
        app:cornerRadius="8dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/rounded_primary_button"/>

</LinearLayout>
