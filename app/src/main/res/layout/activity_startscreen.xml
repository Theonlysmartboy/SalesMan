<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/honeydew">

    <!-- Glowing logo -->
    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_centerInParent="true"
        android:contentDescription="@string/company_name"
        android:src="@drawable/ic_logo"
        android:scaleType="centerInside"
        android:animation="@anim/logo_fade_in"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tagline"
        app:layout_constraintStart_toStartOf="parent"
        />

    <!-- App tagline -->
    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tag_line"
        android:textColor="@color/royal_blue"
        android:textSize="@dimen/_18sp"
        android:layout_below="@id/logoImage"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="@dimen/_20dp"
        android:fontFamily="@font/roboto_midi"
        app:layout_constraintTop_toBottomOf="@+id/logoImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/loader"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Loader -->
    <com.js.salesman.utils.TrailingDotsLoader
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:id="@+id/loader"
        android:layout_margin="@dimen/_20dp"
        android:layout_below="@+id/tagline"
        android:layout_centerHorizontal="true"
        app:layout_constraintTop_toBottomOf="@+id/tagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>