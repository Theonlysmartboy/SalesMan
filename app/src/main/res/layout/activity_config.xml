<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.activity.ConfigActivity"
    android:background="@color/honeydew">

    <!-- Top Guideline for responsiveness -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="@dimen/_106dp" />

    <!-- Logo / Lottie -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="@dimen/_120dp"
        android:layout_height="@dimen/_120dp"
        android:src="@drawable/ic_logo"
        android:contentDescription="@string/app_name"
        app:layout_constraintTop_toBottomOf="@id/topGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/server_link"
        android:textSize="@dimen/_22sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/txtInfo"
        android:layout_marginTop="@dimen/_10dp"/>

    <TextView
        android:id="@+id/txtInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/enter_the_full_link_to_the_server_bellow"
        app:layout_constraintTop_toBottomOf="@id/txtHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="@dimen/_10dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/link_to_backend_scripts"
        app:hintTextColor="?attr/colorSecondary"
        app:layout_constraintTop_toBottomOf="@id/txtInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
        android:layout_margin="@dimen/_20dp">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/edtUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="text"
        android:drawableStart="@drawable/ic_baseline_link_24"
        android:drawablePadding="@dimen/_12dp"/>
</com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tilUrl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginTop="@dimen/_28dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_24dp"
            android:layout_marginBottom="64dp"
            android:text="@string/test"
            android:textColor="@color/white"
            android:fontFamily="@font/roboto_midi"
            android:background="@drawable/rounded_secondary_button"
            app:backgroundTint="@null"
            app:shapeAppearanceOverlay="@null"
            app:rippleColor="@android:color/transparent"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>
        <!-- Next / Finish button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_24dp"
            android:layout_marginBottom="64dp"
            android:text="@string/save"
            android:textColor="@color/white"
            android:fontFamily="@font/roboto_midi"
            android:background="@drawable/rounded_primary_button"
            app:backgroundTint="@null"
            app:rippleColor="@android:color/transparent"
            app:strokeWidth="0dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>