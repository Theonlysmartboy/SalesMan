<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/honeydew">
    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/productToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:title="@string/products"
        app:titleTextColor="@color/honeydew"
        app:menu="@menu/menu_product_search" />

    <!-- Selected Customer Header -->
    <TextView
        android:id="@+id/tvSelectedCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dust_gray"
        android:padding="12dp"
        android:text="Select Customer"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:drawablePadding="8dp"
        android:gravity="center_vertical" />

    <!-- Pull to refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/productSwipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/productRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="vertical" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
